<Window x:Class="TradeTerminal.Desktop.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeTerminal.Desktop.Windows"
        mc:Ignorable="d"
        Title="Просмотр заказа" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" Background="White" FontFamily="Calibri"
        >
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Номер заказа -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Заказ №" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="orderNumberLabel" FontSize="18" FontWeight="Bold"/>
        </StackPanel>

        <!-- Информация о клиенте -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="Клиент: " FontSize="14"/>
            <TextBlock x:Name="clientLabel" FontSize="14" FontWeight="Bold"/>
        </StackPanel>

        <!-- Код получения -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Код получения: " FontSize="14"/>
            <TextBlock x:Name="pickupCodeLabel" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <!-- Список товаров -->
        <ListView x:Name="itemsListView" Grid.Row="3" Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Товар" Width="250" DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Кол-во" Width="70" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Цена" Width="100">
                        <GridViewColumn.DisplayMemberBinding>
                            <Binding Path="Price" StringFormat="{}{0:C}" ConverterCulture="ru-RU"/>
                        </GridViewColumn.DisplayMemberBinding>
                    </GridViewColumn>
                    <GridViewColumn Header="Сумма" Width="100">
                        <GridViewColumn.DisplayMemberBinding>
                            <Binding Path="Total" StringFormat="{}{0:C}" ConverterCulture="ru-RU"/>
                        </GridViewColumn.DisplayMemberBinding>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Итого -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">
            <TextBlock Text="Итого: " FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Name="totalLabel" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="💾 Сохранить талон (txt)" Click="SaveTicketButton_Click" 
                    Style="{StaticResource PrimaryButton}" Width="180" Margin="0,0,10,0"/>
            <Button Content="✅ Оформить заказ" Click="CheckoutButton_Click" 
                    Style="{StaticResource PrimaryButton}" Width="150" Margin="0,0,10,0"/>
            <Button Content="🗑 Очистить корзину" Click="ClearButton_Click" 
                    Style="{StaticResource PrimaryButton}" Width="156" Background="DarkGray"/>
        </StackPanel>
    </Grid>
</Window>
