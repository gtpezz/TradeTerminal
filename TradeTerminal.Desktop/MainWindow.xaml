<Window x:Class="TradeTerminal.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeTerminal.Desktop"
        mc:Ignorable="d"
        Title="Терминал торгового центра"
        Loaded="Window_Loaded"
        Height="750" Width="1100"
        MinHeight="650" MinWidth="950"
        Background="White" FontFamily="Calibri"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Images/icon.png" />
                    <TextBlock Text="Книжный магазин" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="userLabel" Text="Гость" FontSize="14" Foreground="White" 
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <Button Grid.Column="2" x:Name="loginButton" Content="Войти" Click="LoginButton_Click" 
                        Style="{StaticResource PrimaryButton}" Width="90" Margin="0,0,8,0"/>

                <Button Grid.Column="3" x:Name="manageOrdersButton" Content="Заказы" 
                        Click="ManageOrdersButton_Click" Style="{StaticResource PrimaryButton}" 
                        Visibility="Collapsed" Margin="0,0,8,0" Width="100"/>

                <Button Grid.Column="4" x:Name="buttonViewOrder" Content="Корзина" 
                        Click="ButtonViewOrder_Click" Style="{StaticResource PrimaryButton}" 
                        Visibility="Collapsed" Margin="0,0,8,0"/>

                <Button Grid.Column="5" x:Name="btnRefresh" Content="&#x27F3;" 
                        Click="RefreshButton_Click" Style="{StaticResource PrimaryButton}" 
                        Width="40" Margin="0,0,0,0" FontSize="18"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F8F9FA" Padding="10,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                    <TextBlock Text="Поиск" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtSearch" Width="140" Height="30" TextChanged="FilterTextBox_TextChanged" 
                             ToolTip="Введите название" VerticalContentAlignment="Center" MaxLength="50"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                    <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbManufacturer" Width="130" Height="30" 
                              SelectionChanged="FilterComboBox_SelectionChanged" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2,10,2">
                    <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cmbCategory" Width="130" Height="30" 
                              SelectionChanged="FilterComboBox_SelectionChanged" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2,15,2">
                    <TextBlock Text="Цена:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtMinPrice" Width="55" Height="30" TextChanged="FilterTextBox_TextChanged"
                             ToolTip="Мин. цена" VerticalContentAlignment="Center" TextAlignment="Center" MaxLength="20"/>
                    <TextBlock Text="-" VerticalAlignment="Center" FontWeight="Bold" Margin="4,0"/>
                    <TextBox x:Name="txtMaxPrice" Width="55" Height="30" TextChanged="FilterTextBox_TextChanged"
                             ToolTip="Макс. цена" VerticalContentAlignment="Center" TextAlignment="Center" MaxLength="20"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Button x:Name="sortNameButton" Content="Имя" Click="SortNameButton_Click" 
                            Style="{StaticResource PrimaryButton}" Padding="8,5" FontSize="11" Width="85" Height="30" Margin="0,0,5,0"/>
                    <Button x:Name="sortPriceButton" Content="Цена" Click="SortPriceButton_Click" 
                            Style="{StaticResource PrimaryButton}" Padding="8,5" FontSize="11" Width="85" Height="30"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="itemsControl" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ProductDisplayItem}">
                        <Border BorderBrush="LightGray" BorderThickness="1" 
                                Background="White" CornerRadius="5" 
                                Padding="10" Margin="8"
                                Width="270" Height="240">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Image Grid.Row="0" 
                                       Source="{Binding Photo, Converter={StaticResource ImagePathConverter}}" 
                                       Width="60" Height="60" 
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       Margin="0,0,0,5"/>

                                <TextBlock Grid.Row="1" Text="{Binding Name}" 
                                           FontWeight="Bold" FontSize="14" 
                                           TextWrapping="Wrap" MaxHeight="70"/>

                                <TextBlock Grid.Row="2" Text="{Binding ManufacturerName}" 
                                           FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:F2} ₽}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Discount, StringFormat= (скидка {0}%)}" 
                                               Foreground="Red" FontSize="11" Margin="5,0,0,0"
                                               Visibility="{Binding Discount, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <Button Grid.Row="4" Content="Заказать" 
                                        Tag="{Binding Id}"
                                        Click="OrderButton_Click"
                                        Style="{StaticResource PrimaryButton}" 
                                        Padding="10,5" FontSize="12" 
                                        HorizontalAlignment="Left" 
                                        Margin="0,8,0,0"
                                        Height="30"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#F8F9FA" Padding="15,0" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="lblCount" Text="0 из 0" FontSize="13" Foreground="#555" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>